@model GitHubSpyHub.Models.GithubProfile

@{
    ViewData["Title"] = (Model.Name ?? Model.Username) + " - Profile";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }
        .card {
            border-radius: 1rem !important;
        }
        .rounded-4 {
            border-radius: 1rem !important;
        }
    </style>
</head>
<body>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            
            <a href="/Home/Index" class="btn btn-link text-decoration-none text-secondary mb-4 p-0 d-inline-flex align-items-center fw-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                </svg>
                Search Another Developer
            </a>

            <div class="card border-0 shadow-sm overflow-hidden bg-white">
                <div class="p-4" style="height: 120px; background: linear-gradient(135deg, #0d6efd, #003b93);"></div>
                
                <div class="card-body px-4 pb-4 pt-0 text-center position-relative">
                    
                    <div class="position-absolute start-50 translate-middle" style="top: 0;">
                        <img src="@Model.AvatarUrl" 
                             alt="@Model.Username" 
                             class="rounded-circle border border-4 border-white shadow-sm" 
                             style="width: 110px; height: 110px; object-fit: cover;" />
                    </div>
                    
                    <div style="height: 65px;"></div>

                    <h3 class="fw-bold text-dark mb-1">@(Model.Name ?? "No Name Provided")</h3>
                    <p class="text-primary fw-semibold mb-4">@@@Model.Username</p>

                    <div class="row g-2 mb-4">
                        <div class="col-4">
                            <div class="bg-light p-2 rounded-3 border border-light-subtle">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Repos</small>
                                <span class="fw-bold text-dark fs-5">@Model.PublicRepos</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light p-2 rounded-3 border border-light-subtle">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Followers</small>
                                <span class="fw-bold text-dark fs-5">@Model.Followers</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light p-2 rounded-3 border border-light-subtle">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Following</small>
                                <span class="fw-bold text-dark fs-5">@Model.Following</span>
                            </div>
                        </div>
                    </div>

                    <hr class="text-black-50 my-4" />

                    <div class="row g-3 text-start mb-4">
                        <div class="col-12 d-flex align-items-center justify-content-between border-bottom pb-2">
                            <span class="text-secondary small fw-semibold">Location</span>
                            <span class="text-dark fw-medium">@(string.IsNullOrEmpty(Model.Location) ? "Not Specified" : Model.Location)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <div class="col-12 d-flex align-items-center justify-content-between border-bottom pb-2">
                                <span class="text-secondary small fw-semibold">Email</span>
                                <span class="text-dark fw-medium">@Model.Email</span>
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2">
                        <a href="@Model.ProfileUrl" target="_blank" class="btn btn-dark btn-lg fw-semibold shadow-sm py-2 fs-6 d-flex align-items-center justify-content-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-github me-2" viewBox="0 0 16 16">
                                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                            </svg>
                            Launch GitHub Profile
                        </a>
                    </div>

                </div>
            </div>
            
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6Rzvu76RC737V17a717jcLVkt169`Aa561Y2G5Gk16TbNYG7k5W126kWV5v" crossorigin="anonymous"></script>
</body>
</html>