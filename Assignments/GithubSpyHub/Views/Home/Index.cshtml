@{
    ViewData["Title"] = "GitHub Portfolio Spy";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }
        .focus-none:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .input-group:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15) !important;
        }
        .card {
            border-radius: 1rem !important;
        }
        .rounded-circle {
            background-color: #ffffff !important;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 90vh;">
        <div class="col-md-7 col-lg-5 text-center">
            
            <div class="mb-4 d-inline-block p-4 rounded-circle shadow-sm text-primary border border-light-subtle">
                <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-terminal-dash" viewBox="0 0 16 16">
                    <path d="M2 3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1zm12-1a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                    <path d="M10.5 8.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5M2 5.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5m0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
                </svg>
            </div>

            <h1 class="fw-800 display-5 tracking-tight mb-2 text-dark" style="font-weight: 800;">
                Dev-Portfolio <span class="text-primary">Spy</span>
            </h1>
            <p class="text-muted fs-6 mb-4 px-3">
                Explore any developer's GitHub digital footprints, live stats, and core metrics instantly.
            </p>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger d-flex align-items-center justify-content-center border-0 shadow-sm mb-4 py-2 rounded-3" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-triangle-fill me-2" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg>
                    <div class="small fw-medium">@ViewBag.ErrorMessage</div>
                </div>
            }

            <div class="card border-0 shadow-sm bg-white p-4">
                <form action="/Github/ProfileDetails" method="get" class="needs-validation" autocomplete="off">
                    <div class="mb-3 text-start">
                        <label for="usernameInput" class="form-label fw-semibold text-secondary small">GitHub Username</label>
                        <div class="input-group input-group-lg border rounded-3 overflow-hidden">
                            <span class="input-group-text bg-white border-0 text-muted fs-6 pe-1">
                                <span class="fw-medium text-black-50">@@</span>
                            </span>
                            <input type="text" 
                                   id="usernameInput"
                                   name="username" 
                                   class="form-control border-0 bg-white fs-6 ps-1 focus-none" 
                                   placeholder="e.g., Profile Username Here" 
                                   required />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold shadow-sm py-2 fs-6">
                        Analyze Profile
                    </button>
                </form>
            </div>

            <p class="text-muted small mt-4 pt-2">
                Data is fetched live from official <a href="https://api.github.com" target="_blank" class="text-decoration-none text-primary fw-semibold">GitHub REST API</a> endpoints.
            </p>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6Rzvu76RC737V17a717jcLVkt169Aa561Y2G5Gk16TbNYG7k5W126kWV5v" crossorigin="anonymous"></script>
</body>
</html>