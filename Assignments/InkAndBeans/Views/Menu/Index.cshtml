@{
        ViewBag.Title = "Menu Page";
}

<!-- ========================= -->
<!-- MENU HERO SECTION -->
<!-- ========================= -->

<section class="menu-hero">

  <div class="menu-hero-content">

    <h1>Crafted Coffee & Delicious Bites</h1>

    <p>
      Explore our handcrafted coffee, fresh desserts,
      and cozy café favorites made with love.
    </p>

  </div>

</section>

<!-- ========================= -->
<!-- MENU CATEGORY BUTTONS -->
<!-- ========================= -->

<section class="menu-categories">

  <button class="menu-category-btn menu-active-btn">All Menu</button>

  <button class="menu-category-btn">Hot Coffee</button>

  <button class="menu-category-btn">Cold Coffee</button>

  <button class="menu-category-btn">Desserts</button>

  <button class="menu-category-btn">Snacks</button>

</section>

<!-- ========================= -->
<!-- HOT COFFEE SECTION -->
<!-- ========================= -->

<section class="menu-section menu-hot-section">

  <div class="menu-section-title">

    <h2>Hot Coffee</h2>

    <p>Freshly brewed comfort in every sip.</p>

  </div>

  <div class="menu-grid">

    <!-- ITEM 1 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Cappuccino</h3>

          <span>$4</span>

        </div>

        <p>
          Rich espresso blended with creamy steamed milk
          and smooth foam.
        </p>

      </div>

    </div>

    <!-- ITEM 2 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Caramel Latte</h3>

          <span>$5</span>

        </div>

        <p>
          Sweet caramel flavor mixed with premium coffee
          and silky milk.
        </p>

      </div>

    </div>

    <!-- ITEM 3 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Mocha</h3>

          <span>$5</span>

        </div>

        <p>
          Chocolate infused espresso topped with soft cream
          and cocoa dust.
        </p>

      </div>

    </div>

  </div>

</section>

<!-- ========================= -->
<!-- DESSERT SECTION -->
<!-- ========================= -->

<section class="menu-section menu-dessert-section">

  <div class="menu-section-title">

    <h2>Sweet Desserts</h2>

    <p>Perfect treats to enjoy with your coffee.</p>

  </div>

  <div class="menu-grid">

    <!-- ITEM 1 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Chocolate Cake</h3>

          <span>$6</span>

        </div>

        <p>
          Soft layered chocolate cake topped with rich cream
          and cocoa flakes.
        </p>

      </div>

    </div>

    <!-- ITEM 2 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1488477181946-6428a0291777?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Brownie</h3>

          <span>$4</span>

        </div>

        <p>
          Warm gooey brownie served with chocolate drizzle
          and nuts.
        </p>

      </div>

    </div>

    <!-- ITEM 3 -->

    <div class="menu-card">

      <img src="https://images.unsplash.com/photo-1464306076886-da185f6a9d05?q=80&w=1974&auto=format&fit=crop">

      <div class="menu-content">

        <div class="menu-top">

          <h3>Cheesecake</h3>

          <span>$7</span>

        </div>

        <p>
          Creamy cheesecake with smooth texture
          and sweet berry topping.
        </p>

      </div>

    </div>

  </div>

</section>

<!-- ========================= -->
<!-- SPECIAL BANNER -->
<!-- ========================= -->

<section class="menu-special-banner">

  <div class="menu-special-content">

    <h2>Weekend Coffee Special ☕</h2>

    <p>
      Buy any two coffees and get one dessert absolutely free
      every Saturday evening.
    </p>

    <a href="#">Explore Menu</a>

  </div>

</section>