@{
        ViewBag.Title = "Home Page";
}

<!-- HERO SECTION -->

<section class="home-hero">

  <div class="home-hero-content">

    <h1>Where Coffee Meets Stories</h1>

    <p>
      Discover a warm corner filled with handcrafted coffee,
      timeless books, and unforgettable conversations.
      Experience the perfect blend of comfort and creativity.
    </p>

    <div class="home-hero-btns">
      <a href="#" class="home-btn home-primary-btn">Explore Books</a>
      <a href="#" class="home-btn home-secondary-btn">Visit Café</a>
    </div>

  </div>

</section>

<!-- FEATURES -->

<section class="home-features">

  <div class="home-section-title">
    <h2>Cozy Experiences</h2>
    <p>Your peaceful escape from the busy world.</p>
  </div>

  <div class="home-feature-grid">

    <div class="home-feature-card">
      <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1974&auto=format&fit=crop">

      <h3>Premium Coffee</h3>

      <p>
        Freshly brewed coffee crafted with rich flavors
        and warm comfort in every cup.
      </p>
    </div>

    <div class="home-feature-card">
      <img src="https://images.unsplash.com/photo-1526243741027-444d633d7365?q=80&w=1974&auto=format&fit=crop">

      <h3>Curated Books</h3>

      <p>
        Explore inspiring novels, poetry, and timeless classics
        selected for passionate readers.
      </p>
    </div>

    <div class="home-feature-card">
      <img src="https://images.unsplash.com/photo-1511578314322-379afb476865?q=80&w=1974&auto=format&fit=crop">

      <h3>Creative Events</h3>

      <p>
        Join poetry nights, reading clubs, and author meetups
        in a beautiful atmosphere.
      </p>
    </div>

  </div>

</section>

<!-- BOOKS -->

<section class="home-books">

  <div class="home-section-title">
    <h2>Featured Books</h2>
    <p>Stories loved by our readers.</p>
  </div>

  <div class="home-book-container">

    <div class="home-book-card">

      <img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=1974&auto=format&fit=crop">

      <div class="home-book-content">

        <h3>The Silent Patient</h3>

        <p>Mystery & Psychological Thriller</p>

        <div class="home-rating">★★★★★</div>

      </div>

    </div>

    <div class="home-book-card">

      <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=1974&auto=format&fit=crop">

      <div class="home-book-content">

        <h3>Atomic Habits</h3>

        <p>Self Improvement & Motivation</p>

        <div class="home-rating">★★★★★</div>

      </div>

    </div>

    <div class="home-book-card">

      <img src="https://images.unsplash.com/photo-1516979187457-637abb4f9353?q=80&w=1974&auto=format&fit=crop">

      <div class="home-book-content">

        <h3>Little Women</h3>

        <p>Classic Literature & Romance</p>

        <div class="home-rating">★★★★★</div>

      </div>

    </div>

  </div>

</section>

<!-- EVENTS -->

<section class="home-events">

  <div class="home-event-banner">

    <div>

      <h2>Friday Poetry Night</h2>

      <p>
        Enjoy soulful poetry, warm coffee, and inspiring conversations
        with creative minds every Friday evening at Ink & Bean Café.
      </p>

    </div>

    <a href="#" class="home-event-btn">Reserve Seat</a>

  </div>

</section>