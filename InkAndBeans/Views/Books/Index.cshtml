@{
        ViewBag.Title = "Books";
}


<!-- ========================= -->
<!-- BOOKS HERO -->
<!-- ========================= -->

<section class="books-hero">

  <div class="books-hero-content">

    <h1>Discover Beautiful Stories</h1>

    <p>
      Escape into timeless classics, inspiring novels,
      and unforgettable adventures carefully curated for every reader.
    </p>

  </div>

</section>

<!-- ========================= -->
<!-- CATEGORIES -->
<!-- ========================= -->

<section class="books-categories">

  <button class="books-category-btn books-active-btn">All Books</button>

  <button class="books-category-btn">Fiction</button>

  <button class="books-category-btn">Romance</button>

  <button class="books-category-btn">Mystery</button>

  <button class="books-category-btn">Self Growth</button>

</section>

<!-- ========================= -->
<!-- BOOKS SECTION -->
<!-- ========================= -->

<section class="books-page-section">

  <div class="books-page-title">

    <h2>Featured Collection</h2>

    <p>Handpicked books loved by our café readers.</p>

  </div>

  <div class="books-grid">

    <!-- BOOK 1 -->

    <div class="books-page-card">

      <div class="books-page-image">

        <img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=1974&auto=format&fit=crop">

        <div class="books-badge">Best Seller</div>

      </div>

      <div class="books-page-content">

        <h3>The Silent Patient</h3>

        <p class="books-author">By Alex Michaelides</p>

        <p class="books-description">
          A thrilling psychological mystery filled with secrets,
          suspense, and shocking twists.
        </p>

        <div class="books-footer">

          <div class="books-rating">★★★★★</div>

          <a href="#" class="books-read-btn">Read More</a>

        </div>

      </div>

    </div>

    <!-- BOOK 2 -->

    <div class="books-page-card">

      <div class="books-page-image">

        <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=1974&auto=format&fit=crop">

        <div class="books-badge">Popular</div>

      </div>

      <div class="books-page-content">

        <h3>Atomic Habits</h3>

        <p class="books-author">By James Clear</p>

        <p class="books-description">
          Learn how small daily habits can transform
          your productivity and mindset.
        </p>

        <div class="books-footer">

          <div class="books-rating">★★★★★</div>

          <a href="#" class="books-read-btn">Read More</a>

        </div>

      </div>

    </div>

    <!-- BOOK 3 -->

    <div class="books-page-card">

      <div class="books-page-image">

        <img src="https://images.unsplash.com/photo-1516979187457-637abb4f9353?q=80&w=1974&auto=format&fit=crop">

        <div class="books-badge">Classic</div>

      </div>

      <div class="books-page-content">

        <h3>Little Women</h3>

        <p class="books-author">By Louisa May Alcott</p>

        <p class="books-description">
          A heartwarming classic story about love,
          family, dreams, and sisterhood.
        </p>

        <div class="books-footer">

          <div class="books-rating">★★★★★</div>

          <a href="#" class="books-read-btn">Read More</a>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- ========================= -->
<!-- QUOTE SECTION -->
<!-- ========================= -->

<section class="books-quote-section">

  <h2>
    “A reader lives a thousand lives before he dies.”
  </h2>

  <p>
    Step into a peaceful atmosphere where every page tells a story,
    every coffee inspires creativity, and every visit feels magical.
  </p>

</section>