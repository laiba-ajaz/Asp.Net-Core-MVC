@{
        ViewBag.Title = "Contact Page";
}


<!-- ========================= -->
<!-- CONTACT HERO -->
<!-- ========================= -->

<section class="contact-hero">

  <div class="contact-hero-content">

    <h1>Get In Touch</h1>

    <p>
      We'd love to hear from you. Visit our cozy café,
      ask a question, or reserve your favorite reading corner.
    </p>

  </div>

</section>

<!-- ========================= -->
<!-- CONTACT SECTION -->
<!-- ========================= -->

<section class="contact-section">

  <!-- LEFT SIDE -->

  <div class="contact-info">

    <h2>Visit Ink & Bean Café</h2>

    <p>
      Step into a peaceful atmosphere filled with books,
      handcrafted coffee, and warm conversations.
      We are always ready to welcome dreamers and readers.
    </p>

    <!-- INFO BOX -->

    <div class="contact-info-box">

      <div class="contact-info-icon">📍</div>

      <div class="contact-info-content">

        <h3>Location</h3>
        <p>123 Cozy Street, Karachi, Pakistan</p>

      </div>

    </div>

    <!-- INFO BOX -->

    <div class="contact-info-box">

      <div class="contact-info-icon">📞</div>

      <div class="contact-info-content">

        <h3>Phone</h3>
        <p>+92 300 1234567</p>

      </div>

    </div>

    <!-- INFO BOX -->

    <div class="contact-info-box">

      <div class="contact-info-icon">✉️</div>

      <div class="contact-info-content">

        <h3>Email</h3>
        <p>hello@inkandbean.com</p>

      </div>

    </div>

  </div>

  <!-- RIGHT SIDE -->

  <div class="contact-form">

    <h2>Send Message</h2>

    <form>

      <div class="contact-input-group">
        <input type="text" placeholder="Your Name">
      </div>

      <div class="contact-input-group">
        <input type="email" placeholder="Your Email">
      </div>

      <div class="contact-input-group">
        <input type="text" placeholder="Subject">
      </div>

      <div class="contact-input-group">
        <textarea placeholder="Write Your Message"></textarea>
      </div>

      <button class="contact-btn">
        Send Message
      </button>

    </form>

  </div>

</section>

<!-- ========================= -->
<!-- MAP -->
<!-- ========================= -->

<section class="contact-map-section">

  <div class="contact-map-container">

    <iframe 
      src="https://maps.google.com/maps?q=karachi&t=&z=13&ie=UTF8&iwloc=&output=embed">
    </iframe>

  </div>

</section>