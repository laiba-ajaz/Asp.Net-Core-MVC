@{
    Layout = "_EventLayout";
    ViewBag.Title = "Events Page";
}

<!-- ========================= -->
<!-- EVENT PAGE WRAPPER -->
<!-- ========================= -->

<div class="event-page">

    <!-- HERO COVER -->
    <section class="event-cover">

        <div class="cover-content">

            <h1>Ink & Bean Events</h1>

            <p>A magazine of coffee, stories & creative nights</p>

        </div>

    </section>

    <!-- STORY 1 -->
    <section class="story">

        <div class="story-text">

            <h2>Friday Poetry Night</h2>

            <p>Soft lights, emotional words, and coffee that makes silence beautiful.</p>

        </div>

        <div class="story-img img1"></div>

    </section>

    <!-- STORY 2 -->
    <section class="story reverse">

        <div class="story-text">

            <h2>Book Reading Circle</h2>

            <p>Readers gather, stories flow, and time slows down naturally.</p>

        </div>

        <div class="story-img img2"></div>

    </section>

    <!-- STORY 3 -->
    <section class="story">

        <div class="story-text">

            <h2>Open Mic Evening</h2>

            <p>A stage for voices, poetry, music and raw creativity.</p>

        </div>

        <div class="story-img img3"></div>

    </section>

    <!-- CTA -->
    <section class="cta">

        <h2>Join the Next Story</h2>

        <a href="#">Reserve Your Seat</a>

    </section>

</div>